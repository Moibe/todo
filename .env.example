# Copia este archivo a `.env` EN EL DROPLET (NO lo commitees). Lo leen el deploy y pm2.
PORT=3500                     # Puerto local de esta app. SvelteKit usa 300x (3000, 3100, 3200...)
HOST=127.0.0.1                # Siempre localhost; nginx hace el proxy reverso
ORIGIN=https://admin.moibe.me # Requerido por SvelteKit para aceptar POST/form-actions en prod
DATABASE_URL=./local.db       # SQLite local (better-sqlite3 + drizzle)
ADMIN_PASSWORD=cambia-esto    # Contraseña única para entrar al sitio (gate de acceso). En el droplet pon una fuerte.
